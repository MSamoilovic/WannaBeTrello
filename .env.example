# Kopiraj ovaj fajl u .env i popuni vrednosti
# cp .env.example .env

# GENERAL
ASPNETCORE_ENVIRONMENT=Development

# DATABASE
POSTGRES_USER=wannabetrello
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=wannabetrello
POSTGRES_PORT=5432

# API
API_PORT=5000

# JWT - Generiši nasumičan ključ: openssl rand -base64 32
JWT_KEY=change-me-generate-with-openssl-rand-base64-32
JWT_ISSUER=WannabeTrelloIssuer
JWT_AUDIENCE=WannabeTrelloAudience
JWT_EXPIRY_MINUTES=60

# EMAIL - Gmail App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=noreply@wannabetrello.com
FROM_NAME=WannabeTrello

# EMAIL CONFIRMATION
EMAIL_CONFIRMATION_TOKEN_LIFESPAN_HOURS=24

# FRONTEND
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# REDIS
REDIS_ENABLED=false
REDIS_CONNECTION_STRING=redis:6379
REDIS_INSTANCE_NAME=wannabetrello
REDIS_DEFAULT_EXPIRATION_MINUTES=5

# PGADMIN (tools profile only)
PGADMIN_EMAIL=admin@wannabetrello.com
PGADMIN_PASSWORD=change-me-pgadmin-password
PGADMIN_PORT=5050
